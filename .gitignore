# ────────────────────── Python ──────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ────────────────────── Virtual Environments ──────────────────────
venv/
.venv/
env/
.env

# ────────────────────── Training Outputs ──────────────────────
# Checkpoints, results.json, logs — all reproducible
results/
*.pt
*.pth
*.ckpt
logs/
runs/
wandb/

# ────────────────────── Partition JSONs ──────────────────────
# Regeneratable via partition_*.py scripts (each ~8MB, 67MB total)
# Keep the directory via partitions/README.md
partitions/*.json

# ────────────────────── Dataset ──────────────────────
# WHU-GCD dataset lives outside the repo; safeguard against accidental commit
WHU-GCD/

# ────────────────────── IDE / Editor ──────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ────────────────────── Tooling ──────────────────────
# Trunk (trunk.io) auto-managed local sandbox: plugins, logs, cache, internal lint configs
.trunk/

# ────────────────────── Downloaded Pretrained Weights ──────────────────────
# torchange / Changen2 / SAM weights fetched at runtime (do not commit large binaries).
# Changen2 weights cache via HF by default (~/.cache/huggingface), but safeguard any
# weights that land inside the repo (e.g. AnyChange SAM checkpoints).
sam_weights/
*.weights/
*.safetensors
hf_models/

# ────────────────────── OS ──────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────── Jupyter ──────────────────────
.ipynb_checkpoints/

# ────────────────────── Misc ──────────────────────
*.log
.cache/
